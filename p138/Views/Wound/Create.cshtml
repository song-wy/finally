@{
    ViewData["Title"] = "上传伤口照片";
}

<style>
    .wound-upload-box {
        width: 160px;
        height: 160px;
        border: 2px dashed #adb5bd;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        background-color: #f8f9fa;
        transition: border-color .2s, background-color .2s;
    }
    .wound-upload-box:hover {
        border-color: #0d6efd;
        background-color: #e7f1ff;
    }
    .wound-upload-box .plus-icon {
        font-size: 48px;
        color: #6c757d;
        line-height: 1;
        user-select: none;
    }
    .wound-upload-box:hover .plus-icon {
        color: #0d6efd;
    }
    .wound-upload-input {
        position: absolute;
        width: 0;
        height: 0;
        opacity: 0;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
    }
    .wound-upload-wrap {
        position: relative;
        display: inline-block;
    }
    .wound-file-name {
        margin-top: 8px;
        font-size: 0.875rem;
        color: #6c757d;
    }
    .page-header-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 1rem;
    }
    .page-header-row h4 {
        margin-bottom: 0;
    }
    .wound-page .btn { color: #fff !important; min-width: 90px; }
</style>

<div class="mt-3 px-3 wound-page">
    <div class="page-header-row">
        <h4>上传伤口照片</h4>
        <a href="@Url.Action("Index")" class="btn btn-secondary">返回列表</a>
    </div>
    @if (!string.IsNullOrEmpty(ViewBag.Error))
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    <form method="post" enctype="multipart/form-data" class="row g-3">
        <div class="col-12 text-start">
            <div class="wound-upload-wrap">
                <input type="file" class="wound-upload-input" id="photoFile" name="photoFile" accept="image/*" required>
                <label for="photoFile" class="wound-upload-box mb-0" id="uploadBox">
                    <span class="plus-icon">+</span>
                </label>
                <div class="wound-file-name" id="fileNameHint">点击方框选择图片</div>
            </div>
        </div>

        <div class="col-12 text-start">
            <button type="submit" class="btn btn-primary">保存</button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        document.getElementById('photoFile').addEventListener('change', function() {
            var hint = document.getElementById('fileNameHint');
            if (this.files && this.files.length > 0) {
                hint.textContent = '已选: ' + this.files[0].name;
            } else {
                hint.textContent = '点击方框选择图片';
            }
        });
    </script>
}
