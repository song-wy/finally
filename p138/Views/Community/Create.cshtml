@{
    ViewData["Title"] = "发布新帖";
}

<div class="mt-3 px-3">
    <div class="row mb-3">
        <div class="col"><h4 class="mb-0">发布新帖</h4></div>
        <div class="col-auto"><a href="@Url.Action("Index")" class="btn btn-primary text-white">返回列表</a></div>
    </div>

    @if (!string.IsNullOrEmpty(ViewBag.Error))
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    <form method="post" class="row g-3">
        <div class="col-12">
            <label for="title" class="form-label">标题 *</label>
            <input type="text" class="form-control" id="title" name="title" placeholder="请输入帖子标题" required>
        </div>

        <div class="col-12">
            <label for="content" class="form-label">内容 *</label>
            <textarea class="form-control" id="content" name="content" rows="6" placeholder="分享您的经验、心得或问题..." required></textarea>
        </div>

        <div class="col-12">
            <div class="form-check">
                <input class="form-check-input" type="checkbox" name="isAnonymous" id="anonymous">
                <label class="form-check-label" for="anonymous">
                    匿名发布
                </label>
                <div class="form-text">选择匿名发布后，其他用户将看不到您的真实姓名</div>
            </div>
        </div>

        <div class="col-12">
            <div style="background: #f8f9fa; border-left: 4px solid #0b3a66; padding: 16px; border-radius: 4px; margin-bottom: 20px;">
                <h6 style="color: #0b3a66; margin-bottom: 10px;">发帖指南</h6>
                <ul style="margin: 0; padding-left: 20px;">
                    <li>分享您的治疗经验和生活心得</li>
                    <li>提出关于糖尿病管理的问题</li>
                    <li>互相鼓励，传递正能量</li>
                    <li>请保持友善和尊重的交流氛围</li>
                    <li>如需专业医疗建议，请咨询医生</li>
                </ul>
            </div>
        </div>

        <div class="col-12">
            <button type="submit" class="btn btn-primary me-2">发布帖子</button>
        </div>
    </form>
</div>
