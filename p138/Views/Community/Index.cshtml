@model List<DiabetesPatientApp.Models.Post>

@{
    ViewData["Title"] = "患者互动专区";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>🏥 患者互动专区</h2>
            <p class="text-muted">与其他患者分享经验，互相支持</p>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Create")" class="btn btn-primary">📝 发布新帖</a>
            <a href="@Url.Action("Index", "Dashboard")" class="btn btn-secondary">返回</a>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row">
            @foreach (var post in Model)
            {
                <div class="col-md-12 mb-3">
                    <div class="card">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <div class="flex-grow-1">
                                    <h5 class="card-title">
                                        <a href="@Url.Action("Details", new { id = post.PostId })" class="text-decoration-none">
                                            @post.Title
                                        </a>
                                    </h5>
                                    <p class="card-text text-muted">
                                        @(post.Content.Length > 150 ? post.Content.Substring(0, 150) + "..." : post.Content)
                                    </p>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <small class="text-muted">
                                            👤 @(post.IsAnonymous ? "匿名用户" : post.User?.FullName ?? "未知用户") 
                                            📅 @post.CreatedDate.ToString("yyyy-MM-dd HH:mm")
                                            💬 @post.Comments.Count 条评论
                                        </small>
                                        <div>
                                            <a href="@Url.Action("Details", new { id = post.PostId })" class="btn btn-sm btn-outline-primary">查看详情</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center">
            <div class="alert alert-info">
                <h5>暂无帖子</h5>
                <p>成为第一个分享经验的患者吧！</p>
                <a href="@Url.Action("Create")" class="btn btn-primary">发布第一个帖子</a>
            </div>
        </div>
    }
</div>
