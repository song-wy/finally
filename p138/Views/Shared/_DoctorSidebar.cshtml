@{
    var controller = (ViewContext.RouteData.Values["controller"] as string) ?? "";
    var action = (ViewContext.RouteData.Values["action"] as string) ?? "";

    string IsActive(string targetController, string? targetAction = null)
    {
        var controllerMatches = string.Equals(controller, targetController, System.StringComparison.OrdinalIgnoreCase);
        var actionMatches = string.IsNullOrWhiteSpace(targetAction) || string.Equals(action, targetAction, System.StringComparison.OrdinalIgnoreCase);
        return controllerMatches && actionMatches ? "active" : "";
    }
}

