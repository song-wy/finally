@model DiabetesPatientApp.ViewModels.DoctorDashboardViewModel

@{
    ViewData["Title"] = "医生主页";
}

<!-- 增加闪烁动画样式 -->
<style>
    .blink-emergency {
        animation: blinker 1.5s linear infinite;
        font-weight: bold;
    }

    @@keyframes blinker {
        50% { opacity: 0.3; }
    }
</style>

<div class="container-fluid py-4 bg-light min-vh-100">
    <!-- 1. 顶部：极简欢迎语与关键磁贴 -->
    <div class="row g-3 mb-4">
        <div class="col-12 col-md-4">
            <h4 class="fw-bold">早安，@Model.DoctorName</h4>
            <p class="text-muted small">今天有 @Model.NotificationCount 个事项需要您处理。</p>
        </div>
        <div class="col-12 col-md-8">
            <div class="row text-center bg-white rounded-3 shadow-sm py-3 px-2 mx-0">
                <div class="col-3 border-end">
                    <div class="text-muted small">管理患者</div>
                    <div class="h4 mb-0 fw-bold">@Model.PatientCount</div>
                </div>
                <div class="col-3 border-end">
                    <div class="text-muted small text-danger">待办预警</div>
                    <div class="h4 mb-0 fw-bold text-danger">@Model.RecentPatients.Count()</div>
                </div>
                <div class="col-3 border-end">
                    <div class="text-muted small">今日咨询</div>
                    <div class="h4 mb-0 fw-bold">@Model.TodayConsultationCount</div>
                </div>
                <div class="col-3">
                    <div class="text-muted small">启用提醒</div>
                    <div class="h4 mb-0 fw-bold">@Model.ActiveReminderCount</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- 2. 左侧：高优先级任务区（合并预警与待回复） -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-3 mb-4">
                <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold">📈 趋势分析（近14天）</h5>
                    <small class="text-muted">异常触发次数趋势</small>
                </div>
                <div class="card-body">
                    <canvas id="trendChart" height="120"></canvas>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-white border-0 py-3 d-flex justify-content-between">
                    <h5 class="mb-0 fw-bold">🔥 急需处理（异常与消息）</h5>
                    <button class="btn btn-sm btn-link text-decoration-none">查看全部</button>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        @foreach (var p in Model.RecentPatients)
                        {
                            var hasUnread = Model.RecentUnreadMessages.Any(m => m.SenderId == p.UserId);
                            <div class="list-group-item p-3 border-start border-4 @(hasUnread ? "border-danger" : "border-warning")">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center">
                                        <div class="p-2 bg-light rounded-circle me-3">
                                            <i class="bi bi-person text-secondary"></i>
                                        </div>
                                        <div>
                                            <div class="fw-bold">@p.DisplayName</div>
                                            <div class="small text-muted">最近更新: @p.CreatedDate.ToString("HH:mm")</div>
                                        </div>
                                    </div>
                                    <div>
                                        <!-- 根据状态展示不同的标签 -->
                                        <span class="badge bg-danger-subtle text-danger mb-1 d-block">血糖异常</span>
                                        @if(hasUnread){ <span class="badge bg-primary d-block">有新消息</span> }
                                    </div>
                                    <div class="ms-3">
                                        <a href="@Url.Action("Chat", "Consultation", new { doctorId = p.UserId })" class="btn btn-sm btn-primary px-3">立即处理</a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- 3. 右侧：辅助功能与动态 -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-3 mb-4">
                <div class="card-body p-3">
                    <h6 class="fw-bold mb-3">常用工具</h6>
                    <div class="row g-2">
                        <div class="col-6">
                            <a href="@Url.Action("PatientArchives")" class="btn btn-light w-100 py-3 small"><i class="bi bi-folder d-block fs-4"></i>档案</a>
                        </div>
                        <div class="col-6">
                            <a href="@Url.Action("FollowUps")" class="btn btn-light w-100 py-3 small"><i class="bi bi-calendar-check d-block fs-4"></i>回访</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-white border-0 py-3">
                    <h6 class="mb-0 fw-bold">最新动态</h6>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush small">
                        @foreach (var n in Model.Notifications.Take(5))
                        {
                            <li class="list-group-item border-0 border-bottom py-3">
                                <div class="text-dark fw-bold">@n.PatientName</div>
                                <div class="text-muted text-truncate">@n.Content</div>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        (function () {
            const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TrendLabels ?? new List<string>()));
            const bs = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TrendBloodSugarAlerts ?? new List<int>()));
            const fp = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TrendFootPressureAlerts ?? new List<int>()));
            const wound = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TrendWoundAlerts ?? new List<int>()));

            const el = document.getElementById('trendChart');
            if (!el || !window.Chart) return;

            new Chart(el, {
                type: 'line',
                data: {
                    labels,
                    datasets: [
                        {
                            label: '血糖异常',
                            data: bs,
                            borderColor: '#dc3545',
                            backgroundColor: 'rgba(220,53,69,0.12)',
                            tension: 0.35,
                            fill: true
                        },
                        {
                            label: '足压高风险',
                            data: fp,
                            borderColor: '#ffc107',
                            backgroundColor: 'rgba(255,193,7,0.15)',
                            tension: 0.35,
                            fill: true
                        },
                        {
                            label: '伤口异常',
                            data: wound,
                            borderColor: '#6f42c1',
                            backgroundColor: 'rgba(111,66,193,0.12)',
                            tension: 0.35,
                            fill: true
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'bottom' },
                        tooltip: { mode: 'index', intersect: false }
                    },
                    interaction: { mode: 'index', intersect: false },
                    scales: {
                        y: { beginAtZero: true, ticks: { precision: 0 } }
                    }
                }
            });
        })();
    </script>
}