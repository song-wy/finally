@model DiabetesPatientApp.Models.OtherDepartmentDoctor
@{
    ViewData["Title"] = "会诊交流";
}

<div class="container-fluid mt-3">
    <div class="row mb-3">
        <div class="col">
            <h2 class="mb-1">会诊交流</h2>
            <div class="text-muted small">与其他科室医生进行会诊沟通（界面展示，消息仅在当前页面内显示）。</div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header fw-bold">会诊医生</div>
        <div class="card-body">
            <div class="row g-2">
                <div class="col-12 col-md-3">
                    <div class="text-muted small">科室</div>
                    <div class="fw-semibold">@Model.Department</div>
                </div>
                <div class="col-12 col-md-3">
                    <div class="text-muted small">姓名</div>
                    <div class="fw-semibold">@Model.Name</div>
                </div>
                <div class="col-12 col-md-3">
                    <div class="text-muted small">性别</div>
                    <div class="fw-semibold">@Model.Gender</div>
                </div>
                <div class="col-12 col-md-3">
                    <div class="text-muted small">电话</div>
                    <div class="fw-semibold">@Model.PhoneNumber</div>
                </div>
            </div>
            <div class="mt-3">
                <a class="btn btn-sm btn-outline-secondary" href="@Url.Action("MultidisciplinaryConsultation", "Doctor")">返回选择</a>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header fw-bold d-flex justify-content-between align-items-center">
            <span>交流内容</span>
            <button id="clearBtn" type="button" class="btn btn-sm btn-outline-danger">清空</button>
        </div>
        <div class="card-body">
            <div id="chatBox" class="border rounded p-3" style="height: 360px; overflow:auto; background:#fff;">
                <div class="text-muted small">已进入与 @Model.Department @Model.Name 的会诊交流。</div>
            </div>

            <div class="mt-3 d-flex gap-2">
                <input id="msgInput" class="form-control" placeholder="请输入消息…" maxlength="500" />
                <button id="sendBtn" class="btn btn-primary text-white" type="button">发送</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const chatBox = document.getElementById('chatBox');
            const msgInput = document.getElementById('msgInput');
            const sendBtn = document.getElementById('sendBtn');
            const clearBtn = document.getElementById('clearBtn');

            function appendMessage(role, text) {
                const wrap = document.createElement('div');
                wrap.className = 'mt-2';

                const meta = document.createElement('div');
                meta.className = 'text-muted small';
                meta.textContent = `${role} · ${new Date().toLocaleString()}`;

                const bubble = document.createElement('div');
                bubble.className = 'mt-1 p-2 border rounded';
                bubble.style.background = role === '我' ? '#f1f7ff' : '#f8f9fa';
                bubble.textContent = text;

                wrap.appendChild(meta);
                wrap.appendChild(bubble);
                chatBox.appendChild(wrap);
                chatBox.scrollTop = chatBox.scrollHeight;
            }

            function send() {
                const text = (msgInput.value || '').trim();
                if (!text) return;
                msgInput.value = '';
                appendMessage('我', text);

                // 占位：模拟对方已收到（仅界面演示）
                window.setTimeout(() => {
                    appendMessage('对方', '已收到，我会诊后回复。');
                }, 400);
            }

            sendBtn.addEventListener('click', send);
            msgInput.addEventListener('keydown', function (e) {
                if (e.key === 'Enter') send();
            });
            clearBtn.addEventListener('click', function () {
                chatBox.innerHTML = '<div class="text-muted small">已清空。</div>';
            });
        })();
    </script>
}

