@model IEnumerable<DiabetesPatientApp.Models.EducationResource>
@{
    ViewData["Title"] = "健康宣教管理";
    var items = (Model ?? Enumerable.Empty<DiabetesPatientApp.Models.EducationResource>()).ToList();
    var msg = (ViewBag.StatusMessage as string) ?? "";
}

<div class="container-fluid mt-3">
    @if (!string.IsNullOrWhiteSpace(msg))
    {
        <div class="alert alert-info">@msg</div>
    }

    <div class="row mb-3">
        <div class="col">
            <h4 class="mb-0">健康宣教管理</h4>
            <div class="text-muted small">上传宣教短视频/资料，并控制是否在患者端展示。</div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header fw-semibold">上传宣教资源</div>
        <div class="card-body">
            <form method="post" enctype="multipart/form-data" action="@Url.Action("Upload", "Education")">
                @Html.AntiForgeryToken()
                <div class="row g-3">
                    <div class="col-12 col-md-5">
                        <label class="form-label small text-muted">标题</label>
                        <input class="form-control" name="title" maxlength="80" placeholder="例如：糖尿病足日常护理要点" required />
                    </div>
                    <div class="col-12 col-md-2">
                        <label class="form-label small text-muted">类型</label>
                        <select class="form-select" name="resourceType">
                            <option value="视频">视频</option>
                            <option value="文件">文件</option>
                        </select>
                    </div>
                    <div class="col-12 col-md-5">
                        <label class="form-label small text-muted">选择文件</label>
                        <input class="form-control" type="file" name="file" required />
                        <div class="form-text">建议：视频 mp4/webm；文件 pdf/docx/pptx/png/jpg 等。</div>
                    </div>
                </div>
                <div class="mt-3">
                    <button type="submit" class="btn btn-primary text-white">上传</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-header fw-semibold">我的宣教资源</div>
        <div class="card-body">
            @if (items.Count == 0)
            {
                <div class="text-muted">暂无已上传资源。</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-bordered align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>标题</th>
                                <th style="width: 80px;">类型</th>
                                <th>文件</th>
                                <th style="width: 90px;">状态</th>
                                <th style="width: 160px;">上传时间</th>
                                <th style="width: 180px;">操作</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var x in items)
                            {
                                <tr>
                                    <td class="fw-semibold">@x.Title</td>
                                    <td><span class="badge bg-secondary">@x.ResourceType</span></td>
                                    <td>
                                        <a href="@x.FileUrl" target="_blank">@x.OriginalFileName</a>
                                    </td>
                                    <td>
                                        @if (x.IsActive)
                                        {
                                            <span class="badge bg-success">已上架</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">已下架</span>
                                        }
                                    </td>
                                    <td class="text-muted small">@x.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>
                                        <div class="d-flex gap-2">
                                            <form method="post" action="@Url.Action("ToggleActive", "Education")">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@x.EducationResourceId" />
                                                <button type="submit" class="btn btn-sm @(x.IsActive ? "btn-outline-warning" : "btn-outline-success")">
                                                    @(x.IsActive ? "下架" : "上架")
                                                </button>
                                            </form>
                                            <form method="post" action="@Url.Action("Delete", "Education")" onsubmit="return confirm('确认删除该宣教资源？删除后不可恢复。');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@x.EducationResourceId" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger">删除</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

