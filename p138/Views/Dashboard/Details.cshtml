@model DiabetesPatientApp.ViewModels.DashboardRecordDetailsViewModel

@{
    ViewData["Title"] = Model.Title;
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>@Model.Title</h2>
            <p class="text-muted mb-0">统计周期：@Model.PeriodLabel</p>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Index")" class="btn btn-primary btn-sm">返回仪表板</a>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header fw-bold text-primary">数据时间轴</div>
        <div class="card-body">
            <p class="text-muted small mb-3">@(string.IsNullOrWhiteSpace(Model.TimelineHint) ? "以下为血糖记录、伤口上传、足压记录的变化。" : Model.TimelineHint)</p>
            <div style="position:relative;height:280px;">
                <canvas id="patientTimelineChart"></canvas>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header fw-bold text-primary">图表分析</div>
        <div class="card-body">
            <p class="mb-0">@(string.IsNullOrWhiteSpace(Model.ChartAnalysisText) ? "暂无分析。" : Model.ChartAnalysisText)</p>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>
    <script>
        (function () {
            const labels = @Html.Raw(Json.Serialize(Model.TimelineLabels));
            const bs = @Html.Raw(Json.Serialize(Model.TimelineBloodSugarCounts));
            const wound = @Html.Raw(Json.Serialize(Model.TimelineWoundCounts));
            const fp = @Html.Raw(Json.Serialize(Model.TimelineFootPressureCounts));

            const canvas = document.getElementById('patientTimelineChart');
            if (!canvas) return;

            new Chart(canvas.getContext('2d'), {
                type: 'line',
                data: {
                    labels,
                    datasets: [
                        { label: '血糖记录', data: bs, borderColor: 'rgb(255, 193, 7)', backgroundColor: 'rgba(255, 193, 7, 0.12)', fill: true, tension: 0.3 },
                        { label: '伤口上传', data: wound, borderColor: 'rgb(111, 66, 193)', backgroundColor: 'rgba(111, 66, 193, 0.12)', fill: true, tension: 0.3 },
                        { label: '足压记录', data: fp, borderColor: 'rgb(13, 202, 240)', backgroundColor: 'rgba(13, 202, 240, 0.12)', fill: true, tension: 0.3 }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: { mode: 'index', intersect: false },
                    plugins: {
                        legend: { position: 'top' },
                        tooltip: { backgroundColor: '#072a4b', titleColor: '#fff', bodyColor: '#fff' }
                    },
                    scales: {
                        x: { grid: { display: false }, ticks: { maxRotation: 45, minRotation: 0 } },
                        y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,.06)' }, ticks: { precision: 0 } }
                    }
                }
            });
        })();
    </script>
}
