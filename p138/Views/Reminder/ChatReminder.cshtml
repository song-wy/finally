@model List<DiabetesPatientApp.Models.ChatReminderItem>

@{
    ViewData["Title"] = "聊天记录提醒内容";
}

<div class="mt-3 px-3">
    <div class="row mb-3">
        <div class="col"><h4 class="mb-0">聊天记录提醒内容</h4></div>
        <div class="col-auto">
            <a href="@Url.Action("Index")" class="btn btn-primary text-white">返回列表</a>
        </div>
    </div>

    @if (Model != null && Model.Count > 0)
    {
        <p class="text-muted mb-3">以下医生在在线咨询中给您发送了消息，您尚未阅读。</p>
        <div class="list-group">
            @foreach (var item in Model)
            {
                <div class="list-group-item">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div class="flex-grow-1">
                            <div class="mb-2">
                                <strong>@(item.DoctorName)</strong>
                                @(item.UnreadCount == 1 ? "给你发来了一条消息" : $"给你发来了 {item.UnreadCount} 条消息")
                            </div>

                            @if (item.FollowUpDate.HasValue || !string.IsNullOrWhiteSpace(item.FollowUpSummary) || !string.IsNullOrWhiteSpace(item.FollowUpAdvice))
                            {
                                <div class="small text-muted border rounded bg-light px-3 py-2">
                                    <div class="mb-1"><strong>回访日期：</strong>@item.FollowUpDate?.ToString("yyyy-MM-dd")</div>
                                    <div class="mb-1"><strong>回访内容：</strong>@(string.IsNullOrWhiteSpace(item.FollowUpSummary) ? "暂无" : item.FollowUpSummary)</div>
                                    <div><strong>医生建议：</strong>@(string.IsNullOrWhiteSpace(item.FollowUpAdvice) ? "暂无" : item.FollowUpAdvice)</div>
                                </div>
                            }
                        </div>

                        <a href="@Url.Action("Chat", "Consultation", new { doctorId = item.DoctorId })" class="btn btn-primary btn-sm text-white">去查看</a>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info mb-0">
            <h6 class="mb-2">提醒说明</h6>
            <div class="text-muted">
                暂无医生未读回复。当医生在在线咨询中回复您且您未读时，会在此显示「某某医生给你发来了一条消息」。
            </div>
        </div>
    }
</div>
