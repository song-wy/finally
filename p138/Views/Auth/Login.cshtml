@inject DiabetesPatientApp.Services.ISystemSettingsService SystemSettings
@{
    ViewData["Title"] = "用户登录";
    Layout = null;
    var systemName = await SystemSettings.GetStringAsync(DiabetesPatientApp.Services.SystemSettingKeys.SystemName, "糖尿病足管理系统");
    var maintenanceAnnouncement = await SystemSettings.GetStringAsync(DiabetesPatientApp.Services.SystemSettingKeys.MaintenanceAnnouncement, "");
    var allowRegistration = await SystemSettings.GetBoolAsync(DiabetesPatientApp.Services.SystemSettingKeys.AllowRegistration, true);
}

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@systemName</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            width: 100%;
            height: 100%;
        }

        body {
            background: #ffffff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .login-wrapper {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .login-card {
            background: white;
            border-radius: 16px;
            box-shadow: 0 12px 48px rgba(0, 0, 0, 0.12);
            overflow: hidden;
            width: 100%;
            max-width: 420px;
        }

        .login-header {
            background: linear-gradient(135deg, #0b3a66 0%, #072a4b 100%);
            color: white;
            padding: 45px 35px;
            text-align: center;
        }

        .login-header h1 {
            font-size: 26px;
            font-weight: 700;
            margin-bottom: 10px;
            letter-spacing: 0.3px;
        }

        .login-header p {
            font-size: 15px;
            opacity: 0.95;
            font-weight: 300;
        }

        .login-body {
            padding: 45px 35px;
        }

        .form-group {
            margin-bottom: 22px;
        }

        .form-label {
            display: block;
            margin-bottom: 10px;
            font-size: 14px;
            font-weight: 600;
            color: #2c3e50;
        }

        .form-control {
            width: 100%;
            padding: 13px 16px;
            border: 1.5px solid #e0e6ed;
            border-radius: 8px;
            font-size: 14px;
            transition: all 0.3s ease;
            background-color: #f8fafb;
            font-family: inherit;
        }

        .form-control::placeholder {
            color: #bcc1cc;
        }

        .form-control:focus {
            outline: none;
            border-color: #0b3a66;
            background-color: #ffffff;
            box-shadow: 0 0 0 4px rgba(11, 58, 102, 0.08);
        }

        .btn-login {
            width: 100%;
            padding: 14px 16px;
            background: linear-gradient(135deg, #0b3a66 0%, #072a4b 100%);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 12px;
            letter-spacing: 0.5px;
        }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 28px rgba(11, 58, 102, 0.25);
        }

        .btn-login:active {
            transform: translateY(0);
        }

        .divider {
            margin: 35px 0;
            text-align: center;
            position: relative;
        }

        .divider::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 0;
            right: 0;
            height: 1px;
            background: #e0e6ed;
        }

        .divider-text {
            background: white;
            padding: 0 14px;
            color: #9ca3af;
            font-size: 13px;
            position: relative;
        }

        .signup-link {
            text-align: center;
            font-size: 14px;
            color: #6b7280;
        }

        .signup-link a {
            color: #0b3a66;
            text-decoration: none;
            font-weight: 600;
            transition: color 0.3s ease;
        }

        .signup-link a:hover {
            color: #072a4b;
            text-decoration: underline;
        }

        .alert-danger {
            background-color: #fef2f2;
            border: 1.5px solid #fecaca;
            color: #991b1b;
            border-radius: 8px;
            margin-bottom: 24px;
            padding: 12px 16px;
        }

        .alert-danger strong {
            color: #dc2626;
            font-weight: 600;
        }

        .helper-links {
            margin-top: 14px;
            display: flex;
            justify-content: space-between;
            gap: 12px;
            font-size: 13px;
            color: #6b7280;
        }

        .helper-links a {
            color: #0b3a66;
            text-decoration: none;
            font-weight: 600;
        }

        .helper-links a:hover { text-decoration: underline; }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <div class="login-card">
            <div class="login-header">
                <h1>@systemName</h1>
                <p>欢迎登录</p>
            </div>

            <div class="login-body">
                @if (!string.IsNullOrWhiteSpace(maintenanceAnnouncement))
                {
                    <div class="alert-danger" style="background-color:#fff7ed;border-color:#fed7aa;color:#9a3412;">
                        <strong>维护公告：</strong>@maintenanceAnnouncement
                    </div>
                }

                @if (!string.IsNullOrEmpty(ViewBag.Error))
                {
                    <div class="alert-danger">
                        <strong>提示：</strong>@ViewBag.Error
                    </div>
                }

                <form method="post">
                    <div class="form-group">
                        <label for="userrole" class="form-label">请选择用户角色</label>
                        <select class="form-control" id="userrole" name="userrole" required>
                            <option value="" disabled selected>请选择</option>
                            <option value="patient">患者</option>
                            <option value="doctor">医生</option>
                            <option value="admin">管理员</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="username" class="form-label">用户名</label>
                        <input type="text" class="form-control" id="username" name="username" placeholder="请输入您的用户名" required>
                    </div>

                    <div class="form-group">
                        <label for="password" class="form-label">密码</label>
                        <input type="password" class="form-control" id="password" name="password" placeholder="请输入您的密码" required>
                    </div>

                    <button type="submit" class="btn-login">登 录</button>

                    <div class="helper-links">
                        <a href="javascript:void(0);" id="forgotPwdLink">忘记密码？</a>
                        @if (allowRegistration)
                        {
                            <a href="@Url.Action("Register")">去注册</a>
                        }
                        else
                        {
                            <span class="text-muted">注册已关闭</span>
                        }
                    </div>
                </form>

                <div class="divider">
                    <span class="divider-text">还没有账户？</span>
                </div>

                <div class="signup-link">
                    @if (allowRegistration)
                    {
                        <a href="@Url.Action("Register")">立即注册</a>
                    }
                    else
                    {
                        <span>系统已关闭注册</span>
                    }
                </div>
            </div>
        </div>
    </div>

    <script>
        (function () {
            const link = document.getElementById('forgotPwdLink');
            if (!link) return;
            link.addEventListener('click', function () {
                alert('忘记密码请联系管理员重置。');
            });
        })();
    </script>
</body>
</html>

