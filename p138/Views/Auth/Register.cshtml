@{
    ViewData["Title"] = "用户注册";
    Layout = null;
}

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>用户注册</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            width: 100%;
            height: 100%;
        }

        body {
            background: #ffffff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .register-wrapper {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .register-card {
            background: white;
            border-radius: 16px;
            box-shadow: 0 12px 48px rgba(0, 0, 0, 0.12);
            overflow: hidden;
            width: 100%;
            max-width: 420px;
        }

        .register-header {
            background: linear-gradient(135deg, #0b3a66 0%, #072a4b 100%);
            color: white;
            padding: 45px 35px;
            text-align: center;
        }

        .register-header h1 {
            font-size: 26px;
            font-weight: 700;
            margin-bottom: 10px;
            letter-spacing: 0.3px;
        }

        .register-header p {
            font-size: 15px;
            opacity: 0.95;
            font-weight: 300;
        }

        .register-body {
            padding: 45px 35px;
        }

        .form-group {
            margin-bottom: 22px;
        }

        .form-label {
            display: block;
            margin-bottom: 10px;
            font-size: 14px;
            font-weight: 600;
            color: #2c3e50;
            text-transform: none;
        }

        .form-control {
            width: 100%;
            padding: 13px 16px;
            border: 1.5px solid #e0e6ed;
            border-radius: 8px;
            font-size: 14px;
            transition: all 0.3s ease;
            background-color: #f8fafb;
            font-family: inherit;
        }

        .form-control::placeholder {
            color: #bcc1cc;
        }

        .form-control:focus {
            outline: none;
            border-color: #0b3a66;
            background-color: #ffffff;
            box-shadow: 0 0 0 4px rgba(11, 58, 102, 0.08);
        }

        select.form-control {
            cursor: pointer;
            appearance: auto;
            -webkit-appearance: menulist;
            min-height: 44px;
        }

        .btn-register {
            width: 100%;
            padding: 14px 16px;
            background: linear-gradient(135deg, #0b3a66 0%, #072a4b 100%);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 12px;
            letter-spacing: 0.5px;
        }

        .btn-register:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 28px rgba(11, 58, 102, 0.25);
        }

        .btn-register:active {
            transform: translateY(0);
        }

        .divider {
            margin: 35px 0;
            text-align: center;
            position: relative;
        }

        .divider::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 0;
            right: 0;
            height: 1px;
            background: #e0e6ed;
        }

        .divider-text {
            background: white;
            padding: 0 14px;
            color: #9ca3af;
            font-size: 13px;
            position: relative;
        }

        .login-link {
            text-align: center;
            font-size: 14px;
            color: #6b7280;
        }

        .login-link a {
            color: #0b3a66;
            text-decoration: none;
            font-weight: 600;
            transition: color 0.3s ease;
        }

        .login-link a:hover {
            color: #072a4b;
            text-decoration: underline;
        }

        .alert-danger {
            background-color: #fef2f2;
            border: 1.5px solid #fecaca;
            color: #991b1b;
            border-radius: 8px;
            margin-bottom: 24px;
            padding: 12px 16px;
        }

        .alert-danger strong {
            color: #dc2626;
            font-weight: 600;
        }

        .password-hint {
            font-size: 12px;
            color: #9ca3af;
            margin-top: 6px;
        }
    </style>
</head>
<body>
    <div class="register-wrapper">
        <div class="register-card">
            <div class="register-header">
                <h1>糖尿病管理系统</h1>
                <p>用户注册</p>
            </div>

            <div class="register-body">
                @if (!string.IsNullOrEmpty(ViewBag.Error))
                {
                    <div class="alert-danger">
                        <strong>注册失败：</strong>@ViewBag.Error
                    </div>
                }

                <form method="post">
                    <div class="form-group">
                        <label for="userrole" class="form-label">请选择用户角色</label>
                        <select class="form-control" id="userrole" name="userrole" required>
                            <option value="" disabled selected>请选择</option>
                            <option value="patient">患者</option>
                            <option value="doctor">医生</option>
                            <option value="admin">管理员</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="username" class="form-label">用户名</label>
                        <input type="text" class="form-control" id="username" name="username" placeholder="请输入您的用户名" required>
                    </div>

                    <div class="form-group">
                        <label for="password" class="form-label">密码</label>
                        <input type="password" class="form-control" id="password" name="password" placeholder="请输入密码" required>
                        <div class="password-hint">密码至少需要 6 个字符</div>
                    </div>

                    <div class="form-group">
                        <label for="confirmPassword" class="form-label">确认密码</label>
                        <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" placeholder="请再次输入密码" required>
                    </div>

                    <button type="submit" class="btn-register">立即注册</button>
                </form>

                <div class="divider">
                    <span class="divider-text">已有账户？</span>
                </div>

                <div class="login-link">
                    <a href="@Url.Action("Login")">返回登录</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>

