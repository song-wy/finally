@model DiabetesPatientApp.ViewModels.ConsultationQuestionnaireViewModel

@{
    ViewData["Title"] = Model.PageTitle;
    var keywordRaw = (Model.Keyword ?? string.Empty).Trim();
    var keywordParts = keywordRaw
        .Split(new[] { ',', '，', '、', ';', '；', '|', '\n', '\r', '\t' }, StringSplitOptions.RemoveEmptyEntries)
        .Select(x => x.Trim())
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .ToHashSet(StringComparer.OrdinalIgnoreCase);

    bool IsKeywordSelected(string value) => keywordParts.Contains(value);
}

<div class="container-fluid mt-4">
    @if (TempData["Error"] is string errorMessage && !string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <div class="row mb-4">
        <div class="col-md-8">
            <h2>@Model.PageTitle</h2>
        </div>
        <div class="col-md-4 text-end">
            @if (Model.IsDoctorPortal)
            {
                <a href="@Url.Action("Index", "Doctor")" class="btn btn-secondary">返回</a>
            }
            else
            {
                <a href="@Url.Action("Doctors")" class="btn btn-primary">选择医生</a>
                <a href="@Url.Action("Index", "Dashboard")" class="btn btn-secondary">返回</a>
            }
        </div>
    </div>

    @if (Model.IsDoctorPortal)
    {
        <div class="card mb-4">
            <div class="card-header">AI问卷生成</div>
            <div class="card-body">
                <form action="@Url.Action("GenerateQuestionnaire", "Consultation")" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">关键词</label>
                            <input type="hidden" id="keywordHidden" name="keyword" value="@keywordRaw" />
                            <div class="dropdown w-100">
                                <button id="keywordDropdownBtn" class="btn btn-light border w-100 text-start d-flex justify-content-between align-items-center" type="button" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                                    <span id="keywordDropdownText" class="text-muted">请选择关键词（可多选）</span>
                                    <span class="ms-2">▾</span>
                                </button>
                                <div class="dropdown-menu p-2 w-100" style="max-height: 320px; overflow:auto;">
                                    <div class="mb-2">
                                        <input id="keywordFilter" class="form-control form-control-sm" placeholder="输入筛选..." />
                                    </div>
                                    <div class="d-flex gap-2 mb-2">
                                        <button id="keywordSelectAll" type="button" class="btn btn-sm btn-outline-primary">全选</button>
                                        <button id="keywordClearAll" type="button" class="btn btn-sm btn-outline-secondary">清空</button>
                                    </div>
                                    <div id="keywordOptions" class="vstack gap-1">
                                        <label class="dropdown-item-text d-flex align-items-center gap-2">
                                            <input class="form-check-input keyword-check" type="checkbox" value="糖尿病足病因认知程度" @(IsKeywordSelected("糖尿病足病因认知程度") ? "checked" : null) />
                                            <span>糖尿病足病因认知程度</span>
                                        </label>
                                        <label class="dropdown-item-text d-flex align-items-center gap-2">
                                            <input class="form-check-input keyword-check" type="checkbox" value="风险识别程度" @(IsKeywordSelected("风险识别程度") ? "checked" : null) />
                                            <span>风险识别程度</span>
                                        </label>
                                        <label class="dropdown-item-text d-flex align-items-center gap-2">
                                            <input class="form-check-input keyword-check" type="checkbox" value="护理知识了解程度" @(IsKeywordSelected("护理知识了解程度") ? "checked" : null) />
                                            <span>护理知识了解程度</span>
                                        </label>
                                        <label class="dropdown-item-text d-flex align-items-center gap-2">
                                            <input class="form-check-input keyword-check" type="checkbox" value="就医意识" @(IsKeywordSelected("就医意识") ? "checked" : null) />
                                            <span>就医意识</span>
                                        </label>
                                        <label class="dropdown-item-text d-flex align-items-center gap-2">
                                            <input class="form-check-input keyword-check" type="checkbox" value="血糖监测依从性" @(IsKeywordSelected("血糖监测依从性") ? "checked" : null) />
                                            <span>血糖监测依从性</span>
                                        </label>
                                        <label class="dropdown-item-text d-flex align-items-center gap-2">
                                            <input class="form-check-input keyword-check" type="checkbox" value="用药依从性" @(IsKeywordSelected("用药依从性") ? "checked" : null) />
                                            <span>用药依从性</span>
                                        </label>
                                        <label class="dropdown-item-text d-flex align-items-center gap-2">
                                            <input class="form-check-input keyword-check" type="checkbox" value="饮食控制" @(IsKeywordSelected("饮食控制") ? "checked" : null) />
                                            <span>饮食控制</span>
                                        </label>
                                        <label class="dropdown-item-text d-flex align-items-center gap-2">
                                            <input class="form-check-input keyword-check" type="checkbox" value="伤口护理依从性" @(IsKeywordSelected("伤口护理依从性") ? "checked" : null) />
                                            <span>伤口护理依从性</span>
                                        </label>
                                        <label class="dropdown-item-text d-flex align-items-center gap-2">
                                            <input class="form-check-input keyword-check" type="checkbox" value="足畸形评估" @(IsKeywordSelected("足畸形评估") ? "checked" : null) />
                                            <span>足畸形评估</span>
                                        </label>
                                        <label class="dropdown-item-text d-flex align-items-center gap-2">
                                            <input class="form-check-input keyword-check" type="checkbox" value="溃疡史" @(IsKeywordSelected("溃疡史") ? "checked" : null) />
                                            <span>溃疡史</span>
                                        </label>
                                        <label class="dropdown-item-text d-flex align-items-center gap-2">
                                            <input class="form-check-input keyword-check" type="checkbox" value="截肢史" @(IsKeywordSelected("截肢史") ? "checked" : null) />
                                            <span>截肢史</span>
                                        </label>
                                        <label class="dropdown-item-text d-flex align-items-center gap-2">
                                            <input class="form-check-input keyword-check" type="checkbox" value="运动时长" @(IsKeywordSelected("运动时长") ? "checked" : null) />
                                            <span>运动时长</span>
                                        </label>
                                        <label class="dropdown-item-text d-flex align-items-center gap-2">
                                            <input class="form-check-input keyword-check" type="checkbox" value="运动频率" @(IsKeywordSelected("运动频率") ? "checked" : null) />
                                            <span>运动频率</span>
                                        </label>
                                        <label class="dropdown-item-text d-flex align-items-center gap-2">
                                            <input class="form-check-input keyword-check" type="checkbox" value="吸烟史" @(IsKeywordSelected("吸烟史") ? "checked" : null) />
                                            <span>吸烟史</span>
                                        </label>
                                        <label class="dropdown-item-text d-flex align-items-center gap-2">
                                            <input class="form-check-input keyword-check" type="checkbox" value="饮酒史" @(IsKeywordSelected("饮酒史") ? "checked" : null) />
                                            <span>饮酒史</span>
                                        </label>
                                        <label class="dropdown-item-text d-flex align-items-center gap-2">
                                            <input class="form-check-input keyword-check" type="checkbox" value="家庭经济程度" @(IsKeywordSelected("家庭经济程度") ? "checked" : null) />
                                            <span>家庭经济程度</span>
                                        </label>
                                        <label class="dropdown-item-text d-flex align-items-center gap-2">
                                            <input class="form-check-input keyword-check" type="checkbox" value="医疗资源程度" @(IsKeywordSelected("医疗资源程度") ? "checked" : null) />
                                            <span>医疗资源程度</span>
                                        </label>
                                        <label class="dropdown-item-text d-flex align-items-center gap-2">
                                            <input class="form-check-input keyword-check" type="checkbox" value="心血管风险" @(IsKeywordSelected("心血管风险") ? "checked" : null) />
                                            <span>心血管风险</span>
                                        </label>
                                    </div>
                                </div>
                            </div>
                            <div class="form-text">下拉后可勾选多个关键词。</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">补充要求</label>
                            <input class="form-control" name="requirements" value="@Model.Requirements" placeholder="例如：适合门诊初筛，重点关注疼痛和感染风险" />
                        </div>
                    </div>
                    <div class="mt-3">
                        <button type="submit" class="btn btn-primary text-white">AI生成</button>
                    </div>
                </form>

                @if (!string.IsNullOrWhiteSpace(Model.GenerationError))
                {
                    <div class="alert alert-danger mt-3 mb-0">@Model.GenerationError</div>
                }
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>问卷收集</span>
                <small class="text-muted">自动保存并回传的患者问卷</small>
            </div>
            <div class="card-body">
                @if (Model.CollectedQuestionnaires != null && Model.CollectedQuestionnaires.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>患者</th>
                                    <th>问卷标题</th>
                                    <th>发送时间</th>
                                    <th>提交时间</th>
                                    <th style="width: 120px;">状态</th>
                                    <th style="width: 90px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.CollectedQuestionnaires)
                                {
                                    <tr>
                                        <td class="fw-semibold">@item.PatientName</td>
                                        <td>@item.Title</td>
                                        <td class="text-muted">@item.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                        <td class="text-muted">@(item.SubmittedAt.HasValue ? item.SubmittedAt.Value.ToString("yyyy-MM-dd HH:mm") : "-")</td>
                                        <td>
                                            @if (item.IsSubmitted)
                                            {
                                                <span class="badge bg-success">已提交</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning text-dark">未提交</span>
                                            }
                                        </td>
                                        <td class="text-end">
                                            <a class="btn btn-sm btn-primary text-white" href="@Url.Action("ViewCollectedQuestionnaire", "Consultation", new { id = item.QuestionnaireAssignmentId })">查看</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-muted">暂无收集到的问卷。</div>
                }
            </div>
        </div>
    }

    @if (!Model.IsDoctorPortal)
    {
        if (Model.Messages.Count > 0)
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>发送者</th>
                            <th>接收者</th>
                            <th>消息类型</th>
                            <th>内容预览</th>
                            <th>时间</th>
                            <th>状态</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var message in Model.Messages.OrderByDescending(m => m.CreatedDate).Take(20))
                        {
                            <tr>
                                <td>@(message.Sender?.FullName ?? "未知发送者")</td>
                                <td>@(message.Receiver?.FullName ?? "所有人")</td>
                                <td>
                                    @if (message.MessageType == "Text")
                                    {
                                        <span class="badge bg-primary">文本</span>
                                    }
                                    else if (message.MessageType == "Voice")
                                    {
                                        <span class="badge bg-success">语音</span>
                                    }
                                </td>
                                <td>
                                    @if (message.MessageType == "Text")
                                    {
                                        @((message.MessageContent?.Length ?? 0) > 50
                                            ? message.MessageContent!.Substring(0, 50) + "..."
                                            : (message.MessageContent ?? string.Empty))
                                    }
                                    else
                                    {
                                        <span>语音消息</span>
                                    }
                                </td>
                                <td>@message.CreatedDate.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>
                                    @if (!message.IsRead)
                                    {
                                        <span class="badge bg-warning">未读</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">已读</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-info">
                <span>暂无消息，<a href="@Url.Action("Doctors")">选择医生开始咨询</a></span>
            </div>
        }
    }
</div>

@section Scripts {
    <style>
        /* 关键词下拉框：保持白底，不随 hover/focus 变色（覆盖全局按钮主题色） */
        #keywordDropdownBtn,
        #keywordDropdownBtn:hover,
        #keywordDropdownBtn:focus,
        #keywordDropdownBtn:active,
        #keywordDropdownBtn.show {
            background: #fff !important;
            border-color: #ced4da !important;
            color: #111 !important;
        }

        #keywordDropdownBtn:focus {
            box-shadow: none !important;
        }

        #keywordDropdownText.text-muted {
            color: #6c757d !important;
        }

        /* 小按钮文字强制白色（如被主题样式覆盖） */
        #keywordSelectAll,
        #keywordClearAll {
            color: #fff !important;
        }
    </style>
    <script>
        (function () {
            const form = document.querySelector('form[action*="GenerateQuestionnaire"]');
            const hidden = document.getElementById('keywordHidden');
            const dropdownText = document.getElementById('keywordDropdownText');
            const filterInput = document.getElementById('keywordFilter');
            const optionWrap = document.getElementById('keywordOptions');
            const selectAllBtn = document.getElementById('keywordSelectAll');
            const clearAllBtn = document.getElementById('keywordClearAll');
            if (!form || !hidden) return;

            function syncHidden() {
                const selected = Array.from(document.querySelectorAll('.keyword-check'))
                    .filter(c => c.checked)
                    .map(c => (c.value || '').trim())
                    .filter(Boolean);
                hidden.value = selected.join('、');

                if (dropdownText) {
                    if (selected.length === 0) {
                        dropdownText.textContent = '请选择关键词（可多选）';
                        dropdownText.classList.add('text-muted');
                    } else if (selected.length <= 3) {
                        dropdownText.textContent = selected.join('、');
                        dropdownText.classList.remove('text-muted');
                    } else {
                        dropdownText.textContent = `已选择 ${selected.length} 项`;
                        dropdownText.classList.remove('text-muted');
                    }
                }
            }

            document.addEventListener('change', function (e) {
                const t = e.target;
                if (t && t.classList && t.classList.contains('keyword-check')) {
                    syncHidden();
                }
            });

            if (selectAllBtn) {
                selectAllBtn.addEventListener('click', function () {
                    Array.from(document.querySelectorAll('.keyword-check')).forEach(c => c.checked = true);
                    syncHidden();
                });
            }
            if (clearAllBtn) {
                clearAllBtn.addEventListener('click', function () {
                    Array.from(document.querySelectorAll('.keyword-check')).forEach(c => c.checked = false);
                    syncHidden();
                });
            }
            if (filterInput && optionWrap) {
                filterInput.addEventListener('input', function () {
                    const q = (filterInput.value || '').trim().toLowerCase();
                    const items = Array.from(optionWrap.querySelectorAll('label'));
                    items.forEach(lab => {
                        const text = (lab.textContent || '').trim().toLowerCase();
                        lab.style.display = (!q || text.includes(q)) ? '' : 'none';
                    });
                });
            }

            form.addEventListener('submit', syncHidden);
            syncHidden();
        })();
    </script>
}

