@model List<DiabetesPatientApp.Models.ConsultationMessage>

@{
    ViewData["Title"] = "未读消息";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>未读消息</h2>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Index", "Dashboard")" class="btn btn-secondary">返回</a>
        </div>
    </div>

    @if (Model.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>发送者</th>
                        <th>消息类型</th>
                        <th>内容</th>
                        <th>时间</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var message in Model)
                    {
                        <tr>
                            <td>@(message.Sender?.FullName ?? "未知发送者")</td>
                            <td>
                                @if (message.MessageType == "Text")
                                {
                                    <span class="badge bg-primary">文本</span>
                                }
                                else if (message.MessageType == "Voice")
                                {
                                    <span class="badge bg-success">语音</span>
                                }
                            </td>
                            <td>
                                @if (message.MessageType == "Text")
                                {
                                    @message.MessageContent
                                }
                                else if (message.MessageType == "Voice")
                                {
                                    <audio controls style="width: 200px;">
                                        <source src="@message.VoiceFilePath" type="audio/wav">
                                    </audio>
                                }
                            </td>
                            <td>@message.CreatedDate.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                <a href="@Url.Action("Chat", new { doctorId = message.SenderId })" class="btn btn-sm btn-primary">回复</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            暂无未读消息
        </div>
    }
</div>

