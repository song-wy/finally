@model DiabetesPatientApp.ViewModels.AdminAnalyticsViewModel
@{
	ViewData["Title"] = "统计分析";
}

<div class="container-fluid mt-3">
	<h5 class="mb-2">统计分析</h5>
	<p class="text-muted small mb-3">将统计拆分为两个模块：患者数据统计分析与医生数据统计分析，便于管理员快速查看系统运行情况。</p>

	<ul class="nav nav-pills mb-3" id="analyticsTabs" role="tablist">
		<li class="nav-item" role="presentation">
			<button class="nav-link active" id="tab-patient" data-bs-toggle="pill" data-bs-target="#pane-patient" type="button" role="tab" aria-controls="pane-patient" aria-selected="true">
				患者数据统计分析
			</button>
		</li>
		<li class="nav-item" role="presentation">
			<button class="nav-link" id="tab-doctor" data-bs-toggle="pill" data-bs-target="#pane-doctor" type="button" role="tab" aria-controls="pane-doctor" aria-selected="false">
				医生数据统计分析
			</button>
		</li>
	</ul>

	<div class="tab-content" id="analyticsTabContent">
		<div class="tab-pane fade show active" id="pane-patient" role="tabpanel" aria-labelledby="tab-patient">
			<div class="card mb-3">
				<div class="card-header bg-light fw-semibold">患者数据统计分析</div>
				<div class="card-body">
					<div class="row g-3 mb-3">
						<div class="col-6 col-md-4 col-lg-2">
							<div class="card h-100">
								<div class="card-body text-center py-3">
									<div class="text-primary fw-bold small">患者数</div>
									<div class="fs-4">@Model.PatientCount</div>
								</div>
							</div>
						</div>
						<div class="col-6 col-md-4 col-lg-2">
							<div class="card h-100">
								<div class="card-body text-center py-3">
									<div class="text-primary fw-bold small">血糖记录</div>
									<div class="fs-4">@Model.TotalBloodSugarRecords</div>
									@if (Model.AverageBloodSugar.HasValue)
									{
										<small class="text-muted">均值 @Model.AverageBloodSugar.Value.ToString("F1")</small>
									}
								</div>
							</div>
						</div>
						<div class="col-6 col-md-4 col-lg-2">
							<div class="card h-100">
								<div class="card-body text-center py-3">
									<div class="text-primary fw-bold small">伤口上传</div>
									<div class="fs-4">@Model.TotalWoundRecords</div>
									@if (Model.OpenWoundCases > 0)
									{
										<small class="text-muted">异常 @Model.OpenWoundCases</small>
									}
								</div>
							</div>
						</div>
						<div class="col-6 col-md-4 col-lg-2">
							<div class="card h-100">
								<div class="card-body text-center py-3">
									<div class="text-primary fw-bold small">足压记录</div>
									<div class="fs-4">@Model.TotalFootPressureRecords</div>
									@if (Model.HighPressureCases > 0)
									{
										<small class="text-muted">高危 @Model.HighPressureCases</small>
									}
								</div>
							</div>
						</div>
						<div class="col-6 col-md-4 col-lg-2">
							<div class="card h-100">
								<div class="card-body text-center py-3">
									<div class="text-primary fw-bold small">启用提醒</div>
									<div class="fs-4">@Model.ActiveReminderCount</div>
								</div>
							</div>
						</div>
					</div>

					<div class="row g-3 mb-3">
						<div class="col-12">
							<div class="card">
								<div class="card-header bg-light">健康风险概览</div>
								<div class="card-body">
									<div class="row g-2 text-center">
										<div class="col-6 col-md-3">
											<div class="p-2 rounded bg-light">
												<div class="small text-muted">高危血糖占比</div>
												<div class="fw-bold">@(Model.TotalBloodSugarRecords > 0 ? ((double)Model.HighRiskBloodSugarCount / Model.TotalBloodSugarRecords * 100).ToString("F1") : "0")%</div>
												<small class="text-muted">@Model.HighRiskBloodSugarCount / @Model.TotalBloodSugarRecords 条</small>
											</div>
										</div>
										<div class="col-6 col-md-3">
											<div class="p-2 rounded bg-light">
												<div class="small text-muted">高危足占比</div>
												<div class="fw-bold">@(Model.TotalFootPressureRecords > 0 ? ((double)Model.HighPressureCases / Model.TotalFootPressureRecords * 100).ToString("F1") : "0")%</div>
												<small class="text-muted">@Model.HighPressureCases / @Model.TotalFootPressureRecords 条</small>
											</div>
										</div>
										<div class="col-6 col-md-3">
											<div class="p-2 rounded bg-light">
												<div class="small text-muted">伤口异常占比</div>
												<div class="fw-bold">@(Model.TotalWoundRecords > 0 ? ((double)Model.OpenWoundCases / Model.TotalWoundRecords * 100).ToString("F1") : "0")%</div>
												<small class="text-muted">@Model.OpenWoundCases / @Model.TotalWoundRecords 条</small>
											</div>
										</div>
										<div class="col-6 col-md-3">
											<div class="p-2 rounded bg-light">
												<div class="small text-muted">血糖均值</div>
												<div class="fw-bold">@(Model.AverageBloodSugar.HasValue ? Model.AverageBloodSugar.Value.ToString("F1") : "—")</div>
												<small class="text-muted">mmol/L</small>
											</div>
										</div>
									</div>
								</div>
							</div>
						</div>
					</div>

					<div class="card">
						<div class="card-body">
							<h6 class="card-title mb-3">患者数据行为统计</h6>
							<p class="text-muted small mb-2">血糖记录、伤口上传、足压记录、启用提醒、咨询消息、社区发帖（与患者端功能对应）</p>
							<div class="analytics-chart-wrapper" style="height:280px;">
								<canvas id="chartPatientActivity"></canvas>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>

		<div class="tab-pane fade" id="pane-doctor" role="tabpanel" aria-labelledby="tab-doctor">
			<div class="card mb-3">
				<div class="card-header bg-light fw-semibold">医生数据统计分析</div>
				<div class="card-body">
					<div class="row g-3 mb-3">
						<div class="col-6 col-md-4 col-lg-3">
							<div class="card h-100">
								<div class="card-body text-center py-3">
									<div class="text-primary fw-bold small">医生数</div>
									<div class="fs-4">@Model.DoctorCount</div>
								</div>
							</div>
						</div>
						<div class="col-6 col-md-4 col-lg-3">
							<div class="card h-100">
								<div class="card-body text-center py-3">
									<div class="text-primary fw-bold small">咨询消息</div>
									<div class="fs-4">@Model.ConsultationMessageCount</div>
								</div>
							</div>
						</div>
						<div class="col-6 col-md-4 col-lg-3">
							<div class="card h-100">
								<div class="card-body text-center py-3">
									<div class="text-primary fw-bold small">回访登记</div>
									<div class="fs-4">@Model.FollowUpRecordCount</div>
								</div>
							</div>
						</div>
						<div class="col-6 col-md-4 col-lg-3">
							<div class="card h-100">
								<div class="card-body text-center py-3">
									<div class="text-primary fw-bold small">健康问卷</div>
									<div class="fs-4">@Model.QuestionnaireCount</div>
								</div>
							</div>
						</div>
					</div>

					<div class="card">
						<div class="card-body">
							<h6 class="card-title mb-3">医生端工作统计</h6>
							<p class="text-muted small mb-2">咨询消息、回访登记、健康问卷、伤口记录查阅（与医生端功能对应）</p>
							<div class="analytics-chart-wrapper" style="height:280px;">
								<canvas id="chartDoctorActivity"></canvas>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>

	<div class="row g-3 mb-3">
		<div class="col-12">
			<div class="card">
				<div class="card-header bg-light">数据简要分析</div>
				<div class="card-body">
					<p class="text-muted small mb-3">根据当前统计数据自动生成的分析结论与建议，供管理参考。</p>
					@if (Model.AnalysisConclusions.Any())
					{
						<ul class="list-group list-group-flush">
							@foreach (var item in Model.AnalysisConclusions)
							{
								var alertClass = item.Level == "Warning" ? "list-group-item-warning" : item.Level == "Success" ? "list-group-item-success" : "list-group-item-primary";
								<li class="list-group-item @alertClass d-flex flex-column flex-sm-row align-items-start gap-2">
									<span class="fw-semibold">@item.Title</span>
									<span class="small">@item.Content</span>
								</li>
							}
						</ul>
					}
					else
					{
						<p class="text-muted mb-0">暂无分析结论，请先积累部分数据。</p>
					}
				</div>
			</div>
		</div>
	</div>
</div>

@section Scripts {
	<script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>
	<script>
		(function () {
			const patientLabels = @Html.Raw(Json.Serialize(Model.PatientChartLabels));
			const patientData = @Html.Raw(Json.Serialize(Model.PatientChartData));
			const doctorLabels = @Html.Raw(Json.Serialize(Model.DoctorChartLabels));
			const doctorData = @Html.Raw(Json.Serialize(Model.DoctorChartData));

			function createBarChart(id, labels, data, label) {
				const canvas = document.getElementById(id);
				if (!canvas) return;
				new Chart(canvas.getContext('2d'), {
					type: 'bar',
					data: {
						labels: labels,
						datasets: [{
							label: label,
							data: data,
							backgroundColor: 'rgba(11, 58, 102, 0.85)',
							borderRadius: 6,
							maxBarThickness: 36
						}]
					},
					options: {
						responsive: true,
						maintainAspectRatio: false,
						plugins: {
							legend: { display: false },
							tooltip: {
								backgroundColor: '#072a4b',
								titleColor: '#fff',
								bodyColor: '#fff'
							}
						},
						scales: {
							x: { grid: { display: false }, ticks: { maxRotation: 45, minRotation: 0 } },
							y: {
								beginAtZero: true,
								grid: { color: 'rgba(11,58,102,.08)' },
								ticks: { precision: 0, stepSize: 1 }
							}
						}
					}
				});
			}
			createBarChart('chartPatientActivity', patientLabels, patientData, '数量');
			createBarChart('chartDoctorActivity', doctorLabels, doctorData, '数量');
		})();
	</script>
}
