@model IEnumerable<DiabetesPatientApp.Models.AdminEntryLog>
@using System.Linq
@{
    ViewData["Title"] = "系统监控";
    var logs = (Model ?? Enumerable.Empty<DiabetesPatientApp.Models.AdminEntryLog>()).ToList();
    var now = (DateTime)(ViewBag.Now ?? DateTime.Now);
    var dbOk = (bool)(ViewBag.DbOk ?? false);
    var dbError = ViewBag.DbError as string;
    var msg = (TempData["MaintenanceMessage"] as string) ?? "";
    var systemName = (ViewBag.SystemName as string) ?? "糖尿病足管理系统";
    var maintenanceAnnouncement = (ViewBag.MaintenanceAnnouncement as string) ?? "";
    var allowRegistration = (ViewBag.AllowRegistration as string) ?? "true";
    var maxUploadMB = (ViewBag.MaxUploadMB as string) ?? "30";
}

<div class="container-fluid mt-3">
    @if (!string.IsNullOrWhiteSpace(msg))
    {
        <div class="alert alert-info">@msg</div>
    }

    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <div>
            <h4 class="mb-0">系统监控</h4>
            <small class="text-muted">用于管理员快速检查系统运行状态与关键数据指标。</small>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <form method="post" action="@Url.Action("BackfillEntryLogs", "Admin")" class="d-inline-block">
                @Html.AntiForgeryToken()
                <input type="hidden" name="take" value="200" />
                <button type="submit" class="btn btn-outline-secondary">补记账号日志</button>
            </form>
            <a class="btn btn-outline-primary" href="@Url.Action("Monitor", "Admin")">刷新</a>
        </div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-12 col-lg-4">
            <div class="card h-100">
                <div class="card-header fw-semibold">健康检查</div>
                <div class="card-body">
                    <div class="mb-2"><span class="text-muted">服务器时间：</span><span class="fw-semibold">@now.ToString("yyyy-MM-dd HH:mm:ss")</span></div>
                    <div class="mb-2">
                        <span class="text-muted">数据库连接：</span>
                        @if (dbOk)
                        {
                            <span class="badge bg-success">正常</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">异常</span>
                            <div class="text-danger small mt-2">@dbError</div>
                        }
                    </div>
                    <div class="alert alert-light border small mb-0">
                        如遇异常：优先检查数据库文件权限、连接字符串、以及是否存在未重启导致的“新表未创建”情况。
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-lg-8">
            <div class="card h-100">
                <div class="card-header fw-semibold">关键指标</div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-6 col-md-4">
                            <div class="p-3 border rounded bg-light text-center">
                                <div class="small text-muted">患者数</div>
                                <div class="fs-4 fw-bold">@ViewBag.PatientCount</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-4">
                            <div class="p-3 border rounded bg-light text-center">
                                <div class="small text-muted">医生数</div>
                                <div class="fs-4 fw-bold">@ViewBag.DoctorCount</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-4">
                            <div class="p-3 border rounded bg-light text-center">
                                <div class="small text-muted">咨询消息</div>
                                <div class="fs-4 fw-bold">@ViewBag.ConsultationCount</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-4">
                            <div class="p-3 border rounded bg-light text-center">
                                <div class="small text-muted">血糖记录</div>
                                <div class="fs-4 fw-bold">@ViewBag.BloodSugarCount</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-4">
                            <div class="p-3 border rounded bg-light text-center">
                                <div class="small text-muted">伤口记录</div>
                                <div class="fs-4 fw-bold">@ViewBag.WoundCount</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-4">
                            <div class="p-3 border rounded bg-light text-center">
                                <div class="small text-muted">足压记录</div>
                                <div class="fs-4 fw-bold">@ViewBag.FootPressureCount</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header fw-semibold">基础设置（全站生效）</div>
        <div class="card-body">
            <form method="post" action="@Url.Action("SaveBasicSettings","Admin")">
                @Html.AntiForgeryToken()
                <div class="row g-3">
                    <div class="col-12 col-lg-4">
                        <label class="form-label small text-muted">系统名称</label>
                        <input class="form-control" name="systemName" maxlength="40" value="@systemName" placeholder="例如：糖尿病足管理系统" />
                        <div class="form-text">影响：登录页标题/侧边栏品牌名/浏览器标题。</div>
                    </div>
                    <div class="col-12 col-lg-4">
                        <label class="form-label small text-muted">维护公告</label>
                        <input class="form-control" name="maintenanceAnnouncement" maxlength="200" value="@maintenanceAnnouncement" placeholder="例如：系统将于今晚 23:00 维护，期间可能无法使用。" />
                        <div class="form-text">影响：全站顶部提示条（为空则不显示）。</div>
                    </div>
                    <div class="col-12 col-lg-2">
                        <label class="form-label small text-muted">开关注册</label>
                        <select class="form-select" name="allowRegistration">
                            <option value="true" selected="@(allowRegistration.Equals("true", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">允许</option>
                            <option value="false" selected="@(allowRegistration.Equals("false", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">关闭</option>
                        </select>
                        <div class="form-text">关闭后，用户自助注册入口不可用。</div>
                    </div>
                    <div class="col-12 col-lg-2">
                        <label class="form-label small text-muted">上传大小限制（MB）</label>
                        <input class="form-control" name="maxUploadMB" value="@maxUploadMB" />
                        <div class="form-text">影响：宣教/资料/伤口等上传。</div>
                    </div>
                </div>
                <div class="mt-3">
                    <button type="submit" class="btn btn-primary text-white">保存设置</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-header fw-semibold">最近新增账号日志（最近50条）</div>
        <div class="card-body">
            @if (logs.Count == 0)
            {
                <div class="text-muted">暂无日志记录（如果你在“建表之前”新增过账号，可点击上方“补记账号日志”）。</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-bordered align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 70px;">ID</th>
                                <th style="width: 80px;">类型</th>
                                <th>用户名</th>
                                <th>姓名</th>
                                <th>邮箱</th>
                                <th style="width: 140px;">创建时间</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var x in logs)
                            {
                                <tr>
                                    <td>@x.EntryId</td>
                                    <td><span class="badge bg-secondary">@x.UserType</span></td>
                                    <td>@x.Username</td>
                                    <td>@(x.FullName ?? "—")</td>
                                    <td>@x.Email</td>
                                    <td class="text-muted small">@x.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

